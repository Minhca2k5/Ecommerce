<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- USERS / ROLES / USER_ROLES -->
    <changeSet id="v1-001-users-roles" author="minh">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="username" type="VARCHAR(64)"><constraints nullable="false" unique="true"/></column>
            <column name="email" type="VARCHAR(128)"><constraints nullable="false" unique="true"/></column>
            <column name="password" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="full_name" type="VARCHAR(128)"/>
            <column name="phone" type="VARCHAR(32)"/>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="roles">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="name" type="VARCHAR(32)"><constraints nullable="false" unique="true"/></column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createTable tableName="user_roles">
            <column name="user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="role_id" type="BIGINT"><constraints nullable="false"/></column>
        </createTable>

        <addPrimaryKey tableName="user_roles" columnNames="user_id, role_id" constraintName="pk_user_roles"/>
        <addForeignKeyConstraint baseTableName="user_roles" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_ur_user"/>
        <addForeignKeyConstraint baseTableName="user_roles" baseColumnNames="role_id"
                                 referencedTableName="roles" referencedColumnNames="id"
                                 onDelete="RESTRICT" constraintName="fk_ur_role"/>
        <modifySql dbms="mysql">
            <replace
                    replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
                    with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </modifySql>
    </changeSet>

    <!-- ADDRESSES -->
    <changeSet id="v1-002-addresses" author="minh">
        <createTable tableName="addresses">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="line1" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="line2" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(128)"/>
            <column name="state" type="VARCHAR(128)"/>
            <column name="country" type="VARCHAR(64)"/>
            <column name="zipcode" type="VARCHAR(32)"/>
            <column name="is_default" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="addresses" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_addr_user"/>
        <modifySql dbms="mysql">
            <replace
                    replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
                    with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </modifySql>
    </changeSet>

    <!-- CATEGORIES / PRODUCTS / PRODUCT_IMAGES -->
    <changeSet id="v1-003-catalog" author="minh">
        <createTable tableName="categories">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="name" type="VARCHAR(128)"><constraints nullable="false"/></column>
            <column name="slug" type="VARCHAR(128)"><constraints nullable="false" unique="true"/></column>
            <column name="parent_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="categories" baseColumnNames="parent_id"
                                 referencedTableName="categories" referencedColumnNames="id"
                                 onDelete="SET NULL" constraintName="fk_cat_parent"/>

        <createTable tableName="products">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="category_id" type="BIGINT"/>
            <column name="name" type="VARCHAR(160)"><constraints nullable="false"/></column>
            <column name="slug" type="VARCHAR(160)"><constraints nullable="false" unique="true"/></column>
            <column name="sku" type="VARCHAR(64)"><constraints nullable="false" unique="true"/></column>
            <column name="description" type="TEXT"/>
            <column name="price" type="DECIMAL(12,2)"><constraints nullable="false"/></column>
            <column name="currency" type="VARCHAR(8)" defaultValue="VND"/>
            <column name="status" type="VARCHAR(16)" defaultValue="ACTIVE"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="products" baseColumnNames="category_id"
                                 referencedTableName="categories" referencedColumnNames="id"
                                 onDelete="SET NULL" constraintName="fk_prod_cat"/>

        <createTable tableName="product_images">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="product_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="url" type="VARCHAR(512)"><constraints nullable="false"/></column>
            <column name="is_primary" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="product_images" baseColumnNames="product_id"
                                 referencedTableName="products" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_pimg_prod"/>
        <sql>
            ALTER TABLE products ADD CONSTRAINT ck_products_status CHECK (status IN ('ACTIVE','DRAFT','ARCHIVED'));
        </sql>
        <modifySql dbms="mysql">
            <replace
                    replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
                    with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </modifySql>
    </changeSet>

    <!-- CART / CART_ITEMS -->
    <changeSet id="v1-004-cart" author="minh">
        <createTable tableName="carts">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="user_id" type="BIGINT"><constraints nullable="false" unique="true"/></column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="carts" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_cart_user"/>

        <createTable tableName="cart_items">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="cart_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="product_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="unit_price_snapshot" type="DECIMAL(12,2)"><constraints nullable="false"/></column>
            <column name="quantity" type="INT" defaultValueNumeric="1"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="cart_items" baseColumnNames="cart_id"
                                 referencedTableName="carts" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_citem_cart"/>
        <addForeignKeyConstraint baseTableName="cart_items" baseColumnNames="product_id"
                                 referencedTableName="products" referencedColumnNames="id"
                                 onDelete="RESTRICT" constraintName="fk_citem_prod"/>

        <!-- SQL fallback for unsupported addCheckConstraint -->
        <sql>
            ALTER TABLE cart_items ADD CONSTRAINT ck_cart_items_qty_pos CHECK (quantity >= 1);
        </sql>
        <modifySql dbms="mysql">
            <replace
                    replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
                    with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </modifySql>
    </changeSet>

    <!-- ORDERS / ORDER_ITEMS / PAYMENTS -->
    <changeSet id="v1-005-order-payment" author="minh">
        <createTable tableName="orders">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="address_id_snapshot" type="BIGINT"/>
            <column name="total_amount" type="DECIMAL(12,2)"><constraints nullable="false"/></column>
            <column name="voucher_id" type="BIGINT"/>
            <column name="discount_amount" type="DECIMAL(12,2)" defaultValueNumeric="0"/>
            <column name="currency" type="VARCHAR(8)" defaultValue="VND"/>
            <column name="status" type="VARCHAR(16)" defaultValue="PENDING"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="orders" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="RESTRICT" constraintName="fk_order_user"/>

        <createTable tableName="order_items">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="order_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="product_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="product_name_snapshot" type="VARCHAR(160)"/>
            <column name="unit_price_snapshot" type="DECIMAL(12,2)"><constraints nullable="false"/></column>
            <column name="quantity" type="INT" defaultValueNumeric="1"/>
            <column name="line_total" type="DECIMAL(12,2)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="order_items" baseColumnNames="order_id"
                                 referencedTableName="orders" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_oitm_order"/>
        <addForeignKeyConstraint baseTableName="order_items" baseColumnNames="product_id"
                                 referencedTableName="products" referencedColumnNames="id"
                                 onDelete="RESTRICT" constraintName="fk_oitm_product"/>

        <createTable tableName="payments">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="order_id" type="BIGINT"><constraints nullable="false" unique="true"/></column>
            <column name="method" type="VARCHAR(16)" defaultValue="COD"/>
            <column name="amount" type="DECIMAL(12,2)"><constraints nullable="false"/></column>
            <column name="status" type="VARCHAR(16)" defaultValue="INITIATED"/>
            <column name="provider_txn_id" type="VARCHAR(128)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="payments" baseColumnNames="order_id"
                                 referencedTableName="orders" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_pay_order"/>

        <!-- SQL fallbacks for status checks -->
        <sql>ALTER TABLE orders ADD CONSTRAINT ck_orders_status CHECK (status IN ('PENDING','PAID','CANCELLED','SHIPPED'));</sql>
        <sql>ALTER TABLE payments ADD CONSTRAINT ck_payments_status CHECK (status IN ('INITIATED','SUCCEEDED','FAILED'));</sql>
        <modifySql dbms="mysql">
            <replace
                    replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
                    with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </modifySql>
    </changeSet>

    <!-- REVIEWS -->
    <changeSet id="v1-006-reviews" author="minh">
        <createTable tableName="reviews">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true"/></column>
            <column name="user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="product_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="rating" type="INT"><constraints nullable="false"/></column>
            <column name="comment" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="reviews" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_rev_user"/>
        <addForeignKeyConstraint baseTableName="reviews" baseColumnNames="product_id"
                                 referencedTableName="products" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_rev_product"/>

        <!-- SQL fallback for check constraint -->
        <sql>ALTER TABLE reviews ADD CONSTRAINT ck_reviews_rating CHECK (rating BETWEEN 1 AND 5);</sql>
        <modifySql dbms="mysql">
            <replace
                    replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
                    with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </modifySql>
    </changeSet>

    <!-- WAREHOUSES / INVENTORY -->
    <changeSet id="v1-007-inventory-warehouse" author="minh">

        <!-- WAREHOUSES -->
        <createTable tableName="warehouses">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true" />
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false" />
            </column>
            <column name="address" type="VARCHAR(255)" />
            <column name="city" type="VARCHAR(100)" />
            <column name="state" type="VARCHAR(100)" />
            <column name="country" type="VARCHAR(100)" />
            <column name="zipcode" type="VARCHAR(50)" />
            <column name="phone" type="VARCHAR(50)" />
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true" />
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <!-- INVENTORY -->
        <createTable tableName="inventory">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="warehouse_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="stock_qty" type="INT" defaultValueNumeric="0">
                <constraints nullable="false" />
            </column>
            <column name="reserved_qty" type="INT" defaultValueNumeric="0">
                <constraints nullable="false" />
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false"/> </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <!-- FOREIGN KEYS -->
        <addForeignKeyConstraint baseTableName="inventory" baseColumnNames="product_id"
                                 referencedTableName="products" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_inv_prod" />
        <addForeignKeyConstraint baseTableName="inventory" baseColumnNames="warehouse_id"
                                 referencedTableName="warehouses" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_inv_warehouse" />

        <!-- UNIQUE CONSTRAINT -->
        <addUniqueConstraint tableName="inventory"
                             columnNames="product_id, warehouse_id"
                             constraintName="uq_inv_prod_wh" />
        <modifySql dbms="mysql">
            <replace
                    replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
                    with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </modifySql>
    </changeSet>

    <!-- WISHLISTS / RECENT_VIEWS / SEARCH_LOGS / VOUCHERS / VOUCHER_USES / BANNERS -->
    <changeSet id="v1-008-advanced-features" author="minh">

        <!-- WISHLISTS -->
        <createTable tableName="wishlists">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="wishlists" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_wishlist_user"/>
        <addForeignKeyConstraint baseTableName="wishlists" baseColumnNames="product_id"
                                 referencedTableName="products" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_wishlist_product"/>

        <addUniqueConstraint tableName="wishlists"
                             columnNames="user_id, product_id"
                             constraintName="uq_wishlist_user_product"/>

        <!-- RECENT_VIEWS -->
        <createTable tableName="recent_views">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="recent_views" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_recent_view_user"/>
        <addForeignKeyConstraint baseTableName="recent_views" baseColumnNames="product_id"
                                 referencedTableName="products" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_recent_view_product"/>

        <addUniqueConstraint tableName="recent_views"
                             columnNames="user_id, product_id"
                             constraintName="uq_recent_view_user_product"/>

        <!-- SEARCH_LOGS -->
        <createTable tableName="search_logs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT"/>
            <column name="keyword" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="search_logs" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="SET NULL" constraintName="fk_search_logs_user"/>

        <!-- VOUCHERS -->
        <createTable tableName="vouchers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="discount_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="discount_value" type="DECIMAL(12,2)"/>
            <column name="max_discount_amount" type="DECIMAL(12,2)"/>
            <column name="min_order_total" type="DECIMAL(12,2)"/>
            <column name="start_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="end_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="usage_limit_global" type="INT"/>
            <column name="usage_limit_user" type="INT"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <!-- FK orders.voucher_id -> vouchers.id -->
        <addForeignKeyConstraint baseTableName="orders" baseColumnNames="voucher_id"
                                 referencedTableName="vouchers" referencedColumnNames="id"
                                 onDelete="SET NULL" constraintName="fk_orders_voucher"/>

        <!-- CHECK constraints cho vouchers -->
        <sql>
            ALTER TABLE vouchers
            ADD CONSTRAINT ck_vouchers_discount_type CHECK (discount_type IN ('PERCENT','FIXED','FREESHIP'));
        </sql>
        <sql>
            ALTER TABLE vouchers
            ADD CONSTRAINT ck_vouchers_status CHECK (status IN ('ACTIVE','INACTIVE','EXPIRED'));
        </sql>

        <!-- VOUCHER_USES -->
        <createTable tableName="voucher_uses">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="voucher_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="discount_amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="voucher_uses" baseColumnNames="voucher_id"
                                 referencedTableName="vouchers" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_voucher_uses_voucher"/>
        <addForeignKeyConstraint baseTableName="voucher_uses" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_voucher_uses_user"/>
        <addForeignKeyConstraint baseTableName="voucher_uses" baseColumnNames="order_id"
                                 referencedTableName="orders" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_voucher_uses_order"/>

        <!-- BANNERS -->
        <createTable tableName="banners">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="image_url" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="target_url" type="VARCHAR(512)"/>
            <column name="position" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="start_at" type="TIMESTAMP"/>
            <column name="end_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <!-- Patch updated_at cho MySQL -->
        <modifySql dbms="mysql">
            <replace
                    replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
                    with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </modifySql>
    </changeSet>

    <!-- NOTIFICATIONS -->
    <changeSet id="v1-010-notifications" author="minh">

        <createTable tableName="notifications">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="message" type="TEXT">
                <constraints nullable="false"/>
            </column>

            <column name="type" type="VARCHAR(50)" defaultValue="SYSTEM">
                <constraints nullable="false"/>
            </column>

            <column name="reference_id" type="BIGINT"/>
            <column name="reference_type" type="VARCHAR(50)"/>

            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="is_hidden" type="BOOLEAN" defaultValueBoolean="false"/>

            <column name="created_at" type="TIMESTAMP"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP"
                    defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="notifications"
                                 baseColumnNames="user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"
                                 constraintName="fk_notifications_user"/>

        <!-- CHECK (type) -->
        <sql>
            ALTER TABLE notifications
            ADD CONSTRAINT ck_notifications_type
            CHECK (type IN ('ORDER','PAYMENT','VOUCHER','REVIEW','SYSTEM','PROMOTION'));
        </sql>

        <!-- Fix updated_at ON UPDATE CURRENT_TIMESTAMP cho MySQL -->
        <modifySql dbms="mysql">
            <replace
                    replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP"
                    with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"/>
        </modifySql>

    </changeSet>

    <!-- REFRESH TOKENS -->
    <changeSet id="v1-011-refresh-tokens" author="minzetsu">
        <createTable tableName="refresh_tokens">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="expiry_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="refresh_tokens"
                                 constraintName="fk_refresh_tokens_user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>

        <createIndex tableName="refresh_tokens" indexName="idx_refresh_tokens_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <!-- Backfill: create vouchers tables on existing DBs that were initialized before vouchers were added to v1 schema. -->
    <changeSet id="v1-013-backfill-vouchers" author="minh">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="vouchers"/>
            </not>
        </preConditions>

        <createTable tableName="vouchers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="discount_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="discount_value" type="DECIMAL(12,2)"/>
            <column name="max_discount_amount" type="DECIMAL(12,2)"/>
            <column name="min_order_total" type="DECIMAL(12,2)"/>
            <column name="start_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="end_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="usage_limit_global" type="INT"/>
            <column name="usage_limit_user" type="INT"/>
            <column name="status" type="VARCHAR(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <sql>
            ALTER TABLE vouchers
            ADD CONSTRAINT ck_vouchers_discount_type CHECK (discount_type IN ('PERCENT','FIXED','FREESHIP'));
        </sql>
        <sql>
            ALTER TABLE vouchers
            ADD CONSTRAINT ck_vouchers_status CHECK (status IN ('ACTIVE','INACTIVE','EXPIRED'));
        </sql>
    </changeSet>

    <changeSet id="v1-014-backfill-voucher-uses" author="minh">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="voucher_uses"/>
            </not>
        </preConditions>

        <createTable tableName="voucher_uses">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="voucher_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="discount_amount" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="voucher_uses" baseColumnNames="voucher_id"
                                 referencedTableName="vouchers" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_voucher_uses_voucher"/>
        <addForeignKeyConstraint baseTableName="voucher_uses" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_voucher_uses_user"/>
        <addForeignKeyConstraint baseTableName="voucher_uses" baseColumnNames="order_id"
                                 referencedTableName="orders" referencedColumnNames="id"
                                 onDelete="CASCADE" constraintName="fk_voucher_uses_order"/>
    </changeSet>

    <changeSet id="v1-015-backfill-orders-voucher-fk" author="minh">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="orders"/>
                <tableExists tableName="vouchers"/>
                <not>
                    <foreignKeyConstraintExists foreignKeyName="fk_orders_voucher"/>
                </not>
            </and>
        </preConditions>

        <addForeignKeyConstraint baseTableName="orders" baseColumnNames="voucher_id"
                                 referencedTableName="vouchers" referencedColumnNames="id"
                                 onDelete="SET NULL" constraintName="fk_orders_voucher"/>
    </changeSet>

</databaseChangeLog>

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="v10-1-chat-projects" author="codex">
        <createTable tableName="chat_projects">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="DATETIME"/>
        </createTable>

        <createIndex tableName="chat_projects" indexName="idx_chat_projects_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="v10-2-chat-conversations-project" author="codex">
        <addColumn tableName="chat_conversations">
            <column name="project_id" type="BIGINT"/>
        </addColumn>
        <createIndex tableName="chat_conversations" indexName="idx_chat_conversations_project">
            <column name="project_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>

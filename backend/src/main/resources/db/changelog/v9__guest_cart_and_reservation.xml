<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="v9-001-guest-cart" author="minh">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="carts"/>
        </preConditions>

        <dropNotNullConstraint tableName="carts" columnName="user_id" columnDataType="BIGINT"/>

        <addColumn tableName="carts">
            <column name="guest_id" type="VARCHAR(64)"/>
        </addColumn>

        <addUniqueConstraint
                tableName="carts"
                columnNames="guest_id"
                constraintName="uk_carts_guest_id"/>
    </changeSet>

</databaseChangeLog>

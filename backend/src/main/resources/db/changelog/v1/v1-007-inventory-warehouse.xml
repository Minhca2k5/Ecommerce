<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        logicalFilePath="db/changelog/v1__schema.xml"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="v1-007-inventory-warehouse" author="minh" xmlns="http://www.liquibase.org/xml/ns/dbchangelog"><!-- WAREHOUSES --><createTable tableName="warehouses"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="code" type="VARCHAR(50)"><constraints nullable="false" unique="true" /></column><column name="name" type="VARCHAR(200)"><constraints nullable="false" /></column><column name="address" type="VARCHAR(255)" /><column name="city" type="VARCHAR(100)" /><column name="state" type="VARCHAR(100)" /><column name="country" type="VARCHAR(100)" /><column name="zipcode" type="VARCHAR(50)" /><column name="phone" type="VARCHAR(50)" /><column name="is_active" type="BOOLEAN" defaultValueBoolean="true" /><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><!-- INVENTORY --><createTable tableName="inventory"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="product_id" type="BIGINT"><constraints nullable="false" /></column><column name="warehouse_id" type="BIGINT"><constraints nullable="false" /></column><column name="stock_qty" type="INT" defaultValueNumeric="0"><constraints nullable="false" /></column><column name="reserved_qty" type="INT" defaultValueNumeric="0"><constraints nullable="false" /></column><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><!-- FOREIGN KEYS --><addForeignKeyConstraint baseTableName="inventory" baseColumnNames="product_id" referencedTableName="products" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_inv_prod" /><addForeignKeyConstraint baseTableName="inventory" baseColumnNames="warehouse_id" referencedTableName="warehouses" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_inv_warehouse" /><!-- UNIQUE CONSTRAINT --><addUniqueConstraint tableName="inventory" columnNames="product_id, warehouse_id" constraintName="uq_inv_prod_wh" /><modifySql dbms="mysql"><replace replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP" with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP" /></modifySql></changeSet>

</databaseChangeLog>

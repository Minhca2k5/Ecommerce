<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        logicalFilePath="db/changelog/v1__schema.xml"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="v1-005-order-payment" author="minh" xmlns="http://www.liquibase.org/xml/ns/dbchangelog"><createTable tableName="orders"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="user_id" type="BIGINT"><constraints nullable="false" /></column><column name="address_id_snapshot" type="BIGINT" /><column name="total_amount" type="DECIMAL(12,2)"><constraints nullable="false" /></column><column name="voucher_id" type="BIGINT" /><column name="discount_amount" type="DECIMAL(12,2)" defaultValueNumeric="0" /><column name="currency" type="VARCHAR(8)" defaultValue="VND" /><column name="status" type="VARCHAR(16)" defaultValue="PENDING" /><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><addForeignKeyConstraint baseTableName="orders" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" onDelete="RESTRICT" constraintName="fk_order_user" /><createTable tableName="order_items"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="order_id" type="BIGINT"><constraints nullable="false" /></column><column name="product_id" type="BIGINT"><constraints nullable="false" /></column><column name="product_name_snapshot" type="VARCHAR(160)" /><column name="unit_price_snapshot" type="DECIMAL(12,2)"><constraints nullable="false" /></column><column name="quantity" type="INT" defaultValueNumeric="1" /><column name="line_total" type="DECIMAL(12,2)" /><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><addForeignKeyConstraint baseTableName="order_items" baseColumnNames="order_id" referencedTableName="orders" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_oitm_order" /><addForeignKeyConstraint baseTableName="order_items" baseColumnNames="product_id" referencedTableName="products" referencedColumnNames="id" onDelete="RESTRICT" constraintName="fk_oitm_product" /><createTable tableName="payments"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="order_id" type="BIGINT"><constraints nullable="false" unique="true" /></column><column name="method" type="VARCHAR(16)" defaultValue="COD" /><column name="amount" type="DECIMAL(12,2)"><constraints nullable="false" /></column><column name="status" type="VARCHAR(16)" defaultValue="INITIATED" /><column name="provider_txn_id" type="VARCHAR(128)" /><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><addForeignKeyConstraint baseTableName="payments" baseColumnNames="order_id" referencedTableName="orders" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_pay_order" /><!-- SQL fallbacks for status checks --><sql>ALTER TABLE orders ADD CONSTRAINT ck_orders_status CHECK (status IN ('PENDING','PAID','CANCELLED','SHIPPED'));</sql><sql>ALTER TABLE payments ADD CONSTRAINT ck_payments_status CHECK (status IN ('INITIATED','SUCCEEDED','FAILED'));</sql><modifySql dbms="mysql"><replace replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP" with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP" /></modifySql></changeSet>

</databaseChangeLog>

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        logicalFilePath="db/changelog/v1__schema.xml"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="v1-013-backfill-vouchers" author="minh" xmlns="http://www.liquibase.org/xml/ns/dbchangelog"><preConditions onFail="MARK_RAN"><not><tableExists tableName="vouchers" /></not></preConditions><createTable tableName="vouchers"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="code" type="VARCHAR(50)"><constraints nullable="false" unique="true" /></column><column name="name" type="VARCHAR(255)"><constraints nullable="false" /></column><column name="description" type="TEXT" /><column name="discount_type" type="VARCHAR(20)"><constraints nullable="false" /></column><column name="discount_value" type="DECIMAL(12,2)" /><column name="max_discount_amount" type="DECIMAL(12,2)" /><column name="min_order_total" type="DECIMAL(12,2)" /><column name="start_at" type="TIMESTAMP"><constraints nullable="false" /></column><column name="end_at" type="TIMESTAMP"><constraints nullable="false" /></column><column name="usage_limit_global" type="INT" /><column name="usage_limit_user" type="INT" /><column name="status" type="VARCHAR(20)" defaultValue="ACTIVE"><constraints nullable="false" /></column><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><sql>
            ALTER TABLE vouchers
            ADD CONSTRAINT ck_vouchers_discount_type CHECK (discount_type IN ('PERCENT','FIXED','FREESHIP'));
        </sql><sql>
            ALTER TABLE vouchers
            ADD CONSTRAINT ck_vouchers_status CHECK (status IN ('ACTIVE','INACTIVE','EXPIRED'));
        </sql></changeSet>

</databaseChangeLog>

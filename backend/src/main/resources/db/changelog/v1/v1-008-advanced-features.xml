<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        logicalFilePath="db/changelog/v1__schema.xml"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="v1-008-advanced-features" author="minh" xmlns="http://www.liquibase.org/xml/ns/dbchangelog"><!-- WISHLISTS --><createTable tableName="wishlists"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="user_id" type="BIGINT"><constraints nullable="false" /></column><column name="product_id" type="BIGINT"><constraints nullable="false" /></column><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><addForeignKeyConstraint baseTableName="wishlists" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_wishlist_user" /><addForeignKeyConstraint baseTableName="wishlists" baseColumnNames="product_id" referencedTableName="products" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_wishlist_product" /><addUniqueConstraint tableName="wishlists" columnNames="user_id, product_id" constraintName="uq_wishlist_user_product" /><!-- RECENT_VIEWS --><createTable tableName="recent_views"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="user_id" type="BIGINT"><constraints nullable="false" /></column><column name="product_id" type="BIGINT"><constraints nullable="false" /></column><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><addForeignKeyConstraint baseTableName="recent_views" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_recent_view_user" /><addForeignKeyConstraint baseTableName="recent_views" baseColumnNames="product_id" referencedTableName="products" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_recent_view_product" /><addUniqueConstraint tableName="recent_views" columnNames="user_id, product_id" constraintName="uq_recent_view_user_product" /><!-- VOUCHERS --><createTable tableName="vouchers"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="code" type="VARCHAR(50)"><constraints nullable="false" unique="true" /></column><column name="name" type="VARCHAR(255)"><constraints nullable="false" /></column><column name="description" type="TEXT" /><column name="discount_type" type="VARCHAR(20)"><constraints nullable="false" /></column><column name="discount_value" type="DECIMAL(12,2)" /><column name="max_discount_amount" type="DECIMAL(12,2)" /><column name="min_order_total" type="DECIMAL(12,2)" /><column name="start_at" type="TIMESTAMP"><constraints nullable="false" /></column><column name="end_at" type="TIMESTAMP"><constraints nullable="false" /></column><column name="usage_limit_global" type="INT" /><column name="usage_limit_user" type="INT" /><column name="status" type="VARCHAR(20)" defaultValue="ACTIVE"><constraints nullable="false" /></column><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><!-- FK orders.voucher_id -> vouchers.id --><addForeignKeyConstraint baseTableName="orders" baseColumnNames="voucher_id" referencedTableName="vouchers" referencedColumnNames="id" onDelete="SET NULL" constraintName="fk_orders_voucher" /><!-- CHECK constraints cho vouchers --><sql>
            ALTER TABLE vouchers
            ADD CONSTRAINT ck_vouchers_discount_type CHECK (discount_type IN ('PERCENT','FIXED','FREESHIP'));
        </sql><sql>
            ALTER TABLE vouchers
            ADD CONSTRAINT ck_vouchers_status CHECK (status IN ('ACTIVE','INACTIVE','EXPIRED'));
        </sql><!-- VOUCHER_USES --><createTable tableName="voucher_uses"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="voucher_id" type="BIGINT"><constraints nullable="false" /></column><column name="user_id" type="BIGINT"><constraints nullable="false" /></column><column name="order_id" type="BIGINT"><constraints nullable="false" /></column><column name="discount_amount" type="DECIMAL(12,2)"><constraints nullable="false" /></column><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><addForeignKeyConstraint baseTableName="voucher_uses" baseColumnNames="voucher_id" referencedTableName="vouchers" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_voucher_uses_voucher" /><addForeignKeyConstraint baseTableName="voucher_uses" baseColumnNames="user_id" referencedTableName="users" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_voucher_uses_user" /><addForeignKeyConstraint baseTableName="voucher_uses" baseColumnNames="order_id" referencedTableName="orders" referencedColumnNames="id" onDelete="CASCADE" constraintName="fk_voucher_uses_order" /><!-- BANNERS --><createTable tableName="banners"><column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" /></column><column name="title" type="VARCHAR(255)"><constraints nullable="false" /></column><column name="image_url" type="VARCHAR(512)"><constraints nullable="false" /></column><column name="target_url" type="VARCHAR(512)" /><column name="position" type="INT" defaultValueNumeric="0"><constraints nullable="false" /></column><column name="is_active" type="BOOLEAN" defaultValueBoolean="true"><constraints nullable="false" /></column><column name="start_at" type="TIMESTAMP" /><column name="end_at" type="TIMESTAMP" /><column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"><constraints nullable="false" /></column><column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" /></createTable><!-- Patch updated_at cho MySQL --><modifySql dbms="mysql"><replace replace="`updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP" with="`updated_at` TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP" /></modifySql></changeSet>

</databaseChangeLog>



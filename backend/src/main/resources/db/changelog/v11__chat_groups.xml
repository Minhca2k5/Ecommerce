<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="v11-1-chat-groups" author="codex">
        <createTable tableName="chat_groups">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="owner_user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="name" type="VARCHAR(120)"><constraints nullable="false"/></column>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="updated_at" type="DATETIME"/>
        </createTable>
        <createIndex tableName="chat_groups" indexName="idx_chat_groups_owner"><column name="owner_user_id"/></createIndex>
    </changeSet>

    <changeSet id="v11-2-chat-group-members" author="codex">
        <createTable tableName="chat_group_members">
            <column name="id" type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="group_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="role" type="VARCHAR(24)"><constraints nullable="false"/></column>
            <column name="created_at" type="DATETIME"><constraints nullable="false"/></column>
            <column name="updated_at" type="DATETIME"/>
        </createTable>
        <createIndex tableName="chat_group_members" indexName="idx_chat_group_members_group"><column name="group_id"/></createIndex>
        <createIndex tableName="chat_group_members" indexName="idx_chat_group_members_user"><column name="user_id"/></createIndex>
    </changeSet>

    <changeSet id="v11-3-chat-conversation-group" author="codex">
        <addColumn tableName="chat_conversations">
            <column name="group_id" type="BIGINT"/>
        </addColumn>
        <createIndex tableName="chat_conversations" indexName="idx_chat_conversations_group"><column name="group_id"/></createIndex>
    </changeSet>

</databaseChangeLog>

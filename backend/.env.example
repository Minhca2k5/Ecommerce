# =========================
# Spring Profile
# =========================
SPRING_PROFILES_ACTIVE=prod

# =========================
# Database
# =========================
DB_URL=jdbc:mysql://<host>:3306/ecommerce?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=<db_user>
DB_PASSWORD=<db_password>

# =========================
# Security
# =========================
JWT_SECRET_KEY=<strong_random_secret_key>

# =========================
# Redis
# =========================
REDIS_HOST=<redis_host>
REDIS_PORT=6379

# =========================
# RabbitMQ
# =========================
RABBITMQ_HOST=<rabbitmq_host>
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=<rabbitmq_user>
RABBITMQ_PASSWORD=<rabbitmq_password>

# =========================
# Elasticsearch
# =========================
ELASTICSEARCH_URIS=http://<elasticsearch_host>:9200

# =========================
# MoMo (Sandbox/Prod)
# =========================
MOMO_PARTNER_CODE=<momo_partner_code>
MOMO_ACCESS_KEY=<momo_access_key>
MOMO_SECRET_KEY=<momo_secret_key>
MOMO_ENDPOINT=https://test-payment.momo.vn
MOMO_REDIRECT_URL=https://<frontend-domain>/orders
MOMO_IPN_URL=https://<api-domain>/api/public/payments/momo/ipn

# =========================
# Mail SMTP
# =========================
MAIL_USERNAME=<smtp_username>
MAIL_PASSWORD=<smtp_password_or_app_password>
MAIL_LOG_LEVEL=INFO

# =========================
# Chatbot Provider
# =========================
# If no LLM endpoint in cloud, set CHATBOT_ENABLED=false
CHATBOT_ENABLED=false
CHATBOT_BASE_URL=http://<llm-host>:11434
CHATBOT_API_KEY=
CHATBOT_MODEL=llama3.2:1b

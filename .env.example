# Docker Compose env template.
# This file is for docker-compose variable substitution at project root.
# It is separate from backend/.env.properties (used by local Spring Boot run without Docker).
# Usage: copy to .env, fill real secrets, and do not commit .env.

# =========================
# Core profile
# =========================
SPRING_PROFILES_ACTIVE=prod

# =========================
# MySQL
# =========================
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=ecommerce
MYSQL_USER=ecommerce
MYSQL_PASSWORD=change_me_db
MYSQL_HOST_PORT=3307

# =========================
# Security
# =========================
JWT_SECRET_KEY=change_me_jwt_secret

# =========================
# MoMo
# =========================
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=https://your-frontend-domain/orders
MOMO_IPN_URL=https://your-backend-domain/api/public/payments/momo/ipn

# =========================
# RabbitMQ
# =========================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_AMQP_HOST_PORT=5673
RABBITMQ_MGMT_HOST_PORT=15673

# =========================
# Infra host port mapping
# =========================
REDIS_HOST_PORT=6380
ELASTICSEARCH_HOST_PORT=9201
MONGODB_HOST_PORT=27018

# =========================
# Mail SMTP
# =========================
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_LOG_LEVEL=INFO

# =========================
# Chatbot Provider
# =========================
CHATBOT_BASE_URL=
CHATBOT_API_KEY=
CHATBOT_MODEL=

# =========================
# Guest Checkout
# =========================
GUEST_CHECKOUT_USERNAME=guest.checkout
GUEST_CHECKOUT_EMAIL=guest.checkout@example.com
GUEST_CHECKOUT_PASSWORD=change_me_guest_password
GUEST_CHECKOUT_ACCESS_TOKEN_SECRET=change_me_guest_token_secret

# =========================
# Frontend build arg
# =========================
VITE_API_BASE_URL=https://your-backend-domain

# =========================
# Ngrok (local callback tunnel)
# =========================
NGROK_AUTHTOKEN=

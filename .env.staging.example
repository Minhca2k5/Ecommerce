# Staging runtime env (server-side).
# Copy to `.env.staging` on the staging host, then fill real secrets.

# =========================
# Core profile
# =========================
SPRING_PROFILES_ACTIVE=prod

# =========================
# MySQL
# =========================
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=ecommerce
MYSQL_USER=ecommerce
MYSQL_PASSWORD=change_me_db
MYSQL_HOST_PORT=3307

# =========================
# Infra host port mapping
# =========================
REDIS_HOST_PORT=6380
RABBITMQ_AMQP_HOST_PORT=5673
RABBITMQ_MGMT_HOST_PORT=15673
ELASTICSEARCH_HOST_PORT=9201
MONGODB_HOST_PORT=27018

# =========================
# Security
# =========================
JWT_SECRET_KEY=change_me_jwt_secret

# =========================
# MoMo
# =========================
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=https://staging.your-frontend-domain/orders
MOMO_IPN_URL=https://staging.your-backend-domain/api/public/payments/momo/ipn

# =========================
# RabbitMQ
# =========================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# =========================
# Mail SMTP
# =========================
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_LOG_LEVEL=INFO

# =========================
# Chatbot Provider
# =========================
CHATBOT_BASE_URL=
CHATBOT_API_KEY=
CHATBOT_MODEL=

# =========================
# Guest Checkout
# =========================
GUEST_CHECKOUT_USERNAME=guest.checkout
GUEST_CHECKOUT_EMAIL=guest.checkout@example.com
GUEST_CHECKOUT_PASSWORD=change_me_guest_password
GUEST_CHECKOUT_ACCESS_TOKEN_SECRET=change_me_guest_token_secret

# =========================
# Frontend build arg
# =========================
VITE_API_BASE_URL=https://staging.your-backend-domain

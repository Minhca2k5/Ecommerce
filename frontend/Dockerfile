FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
ARG VITE_API_BASE_URL
ARG VITE_MOMO_SANDBOX_ENABLED
ARG VITE_MANUAL_MOMO_ACCOUNT_NAME
ARG VITE_MANUAL_MOMO_ACCOUNT_NUMBER
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_MOMO_SANDBOX_ENABLED=${VITE_MOMO_SANDBOX_ENABLED}
ENV VITE_MANUAL_MOMO_ACCOUNT_NAME=${VITE_MANUAL_MOMO_ACCOUNT_NAME}
ENV VITE_MANUAL_MOMO_ACCOUNT_NUMBER=${VITE_MANUAL_MOMO_ACCOUNT_NUMBER}
RUN npm run build

FROM nginx:1.27-alpine

# SPA fallback + static asset serving.
RUN printf 'server {\n  listen 80;\n  server_name _;\n  root /usr/share/nginx/html;\n  index index.html;\n\n  location / {\n    try_files $uri $uri/ /index.html;\n  }\n}\n' > /etc/nginx/conf.d/default.conf

COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
